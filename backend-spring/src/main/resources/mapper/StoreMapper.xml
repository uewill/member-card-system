<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.membercard.mapper.StoreMapper">

    <resultMap id="storeResultMap" type="com.membercard.entity.Store">
        <id property="id" column="id"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="name" column="name"/>
        <result property="address" column="address"/>
        <result property="phone" column="phone"/>
        <result property="businessHours" column="business_hours"/>
        <result property="status" column="status"/>
        <result property="allowedCardUsage" column="allowed_card_usage"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findPagedByTenantId" resultMap="storeResultMap">
        SELECT * FROM store
        WHERE tenant_id = #{tenantId}
        ORDER BY created_at DESC
        LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <select id="countByTenantId" resultType="int">
        SELECT COUNT(*) FROM store WHERE tenant_id = #{tenantId}
    </select>

</mapper>
