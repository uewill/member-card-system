<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.membercard.mapper.ServiceItemMapper">

    <resultMap id="serviceItemResultMap" type="com.membercard.entity.ServiceItem">
        <id property="id" column="id"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="name" column="name"/>
        <result property="category" column="category"/>
        <result property="price" column="price"/>
        <result property="duration" column="duration"/>
        <result property="purchasableAlone" column="purchasable_alone"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findPagedByTenantId" resultMap="serviceItemResultMap">
        SELECT * FROM service_item
        WHERE tenant_id = #{tenantId}
        ORDER BY created_at DESC
        LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <select id="countByTenantId" resultType="int">
        SELECT COUNT(*) FROM service_item WHERE tenant_id = #{tenantId}
    </select>

</mapper>
