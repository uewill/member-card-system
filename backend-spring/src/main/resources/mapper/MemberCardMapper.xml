<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.membercard.mapper.MemberCardMapper">

    <resultMap id="memberCardResultMap" type="com.membercard.entity.MemberCard">
        <id property="id" column="id"/>
        <result property="tenantId" column="tenant_id"/>
        <result property="memberId" column="member_id"/>
        <result property="packageSnapshotJson" column="package_snapshot_json"/>
        <result property="type" column="type"/>
        <result property="remainingCountsJson" column="remaining_counts_json"/>
        <result property="principalBalance" column="principal_balance"/>
        <result property="bonusBalance" column="bonus_balance"/>
        <result property="expiryDate" column="expiry_date"/>
        <result property="status" column="status"/>
        <result property="cardNo" column="card_no"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findPagedByTenantId" resultMap="memberCardResultMap">
        SELECT * FROM member_card
        WHERE tenant_id = #{tenantId}
        ORDER BY created_at DESC
        LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <select id="countByTenantId" resultType="int">
        SELECT COUNT(*) FROM member_card WHERE tenant_id = #{tenantId}
    </select>

    <select id="findActiveByMemberId" resultMap="memberCardResultMap">
        SELECT * FROM member_card
        WHERE tenant_id = #{tenantId} AND member_id = #{memberId} AND status = 'active'
        ORDER BY created_at DESC
    </select>

</mapper>
